{
  "functions": {
    "api/fidelis-page.js": {
      "includeFiles": "public/fidelis/index.html,public/fidelis-gate.html,public/fidelis-admin.html"
    }
  },
  "routes": [
    { "src": "/vps/(.*)", "dest": "https://vps.signalboss.net/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "fidelis.signalboss.net" }],
      "dest": "/api/fidelis-page"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
